msgid "Image updated"
msgstr "Image mise à jour"

msgid "No images found on openclipart"
msgstr "Aucune image trouvée sur openclipart"

msgid "No images found on FreeSVG"
msgstr "Aucune image trouvée sur FreeSVG"

msgid "No public domain images on Wikimedia"
msgstr "Aucune image du domaine public sur Wikimedia"

msgid "{count} images from {source}"
msgstr "{count} images depuis {source}"

msgid "Enter both GitLab username and token."
msgstr "Saisissez le nom d’utilisateur et le jeton GitLab."

msgid "GitLab credentials saved for {username}"
msgstr "Identifiants GitLab enregistrés pour {username}"

msgid "Code copied to clipboard"
msgstr "Code copié dans le presse-papiers"

msgid "GitHub App client_id not configured."
msgstr "Le client_id de l’appli GitHub n’est pas configuré."

