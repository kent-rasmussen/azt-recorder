# This catalog holds only peer-specific strings. UI primitives
# (Cancel/OK/Clone/Continue/...), status-code messages
# (Committed./Pushed.../Pulled.../...), GitHub/GitLab credential
# flow, welcome/picker/clone-form vocabulary, and image-cache
# wording all live in the client catalog
# (azt_collab_client/locales/<lang>/LC_MESSAGES/azt_collab_client.po).
# The recorder's gettext chain has the client catalog as the
# add_fallback target (CLIENT_INTEGRATION.md § 6), so client-owned
# strings translate without per-peer duplication.

# ── Recorder screen ──────────────────────────────────────────────────────────

msgid "Recording:"
msgstr "Enregistrement :"

msgid "Gloss languages"
msgstr "Langues de glose"

msgid "Filter words"
msgstr "Filtrer les mots"

msgid "CAWL number or range (e.g. 1-100, 42, leave blank for all)"
msgstr "Numéro ou plage CAWL (ex. 1-100, 42, vide = tous)"

msgid "e.g. 1-500"
msgstr "ex. 1-500"

msgid "Gloss search (filter by gloss text)"
msgstr "Recherche de glose (filtrer par texte de glose)"

msgid "search gloss text…"
msgstr "rechercher une glose…"

msgid "Setup Collaboration"
msgstr "Configurer la collaboration"

msgid "Show past work"
msgstr "Afficher le travail passé"

