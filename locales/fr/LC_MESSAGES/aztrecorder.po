msgstr "non enregistrés uniquement"

# ── v1.21.0 additions ──────────────────────────────────────────────────────

msgid "You need to set up collaboration to do this."
msgstr "Vous devez configurer la collaboration pour faire cela."

msgid "Your data isn't being backed up! Please set up collaboration, so your data can be backed up automatically while you work."
msgstr "Vos données ne sont pas sauvegardées ! Veuillez configurer la collaboration pour que vos données soient sauvegardées automatiquement pendant que vous travaillez."

msgid "Later"
msgstr "Plus tard"

msgid "Now install the app to grant repository access."
msgstr "Installez maintenant l'application pour accorder l'accès aux dépôts."

msgid "Select \"All repositories\"."
msgstr "Sélectionnez « Tous les dépôts »."

# ── v1.37.12 additions ─────────────────────────────────────────────────────

msgid "Select Project"
msgstr "Sélectionner un projet"

msgid "Open Sync Settings"
msgstr "Ouvrir les paramètres de synchronisation"

msgid "(none selected)"
msgstr "(aucune sélectionnée)"

msgid "Done"
msgstr "Terminé"

msgid "Opened sync settings."
msgstr "Paramètres de synchronisation ouverts."

msgid "Sync settings UI is desktop-only for now."
msgstr "L'interface des paramètres de synchronisation n'est disponible que sur ordinateur pour l'instant."

msgid "Sync settings UI failed to start: {detail}"
msgstr "L'interface des paramètres de synchronisation n'a pas pu démarrer : {detail}"

msgid "Could not open sync settings: {error}"
msgstr "Impossible d'ouvrir les paramètres de synchronisation : {error}"

msgid "GitHub App install URL not available."
msgstr "URL d'installation de l'appli GitHub indisponible."

msgid "not backed up"
msgstr "non sauvegardé"

# v1.46.0 — blocker-aware variants of "not backed up". Picked in
# main.py:_not_backed_up_text when last_sync == 0: probes contributor
# name → sign-in → project remote and surfaces whichever is missing.
# "Sauvegarder" keeps continuity with the fallback "non sauvegardé"
# above. Infinitive imperative parallels the English "<verb> to back up"
# structure and is the idiomatic French for short instructional UI.
msgid "add name to back up"
msgstr "ajouter un nom pour sauvegarder"

msgid "sign in to back up"
msgstr "se connecter pour sauvegarder"

msgid "publish to back up"
msgstr "publier pour sauvegarder"

msgid "Could not open project picker: {error}"
msgstr "Impossible d'ouvrir le sélecteur de projet : {error}"

# ── v1.41.x additions ──────────────────────────────────────────────────────

msgid "This project"
msgstr "Ce projet"

msgid "Sync interrupted, please try again."
msgstr "Synchronisation interrompue, veuillez réessayer."

msgid "Go to {label} number ({lo}-{hi})"
msgstr "Aller au numéro de {label} ({lo}-{hi})"

msgid "list"
msgstr "liste"

msgid "Hold the button to record"
msgstr "Maintenez le bouton pour enregistrer"

msgid "Audio quality:"
msgstr "Qualité audio :"

# Audio quality labels — main.py's _AUDIO_QUALITY_LABELS tuple
# maps profile-key → label, and the labels reach gettext via
# _tr(label) (variable, not literal). Static .po audits will flag
# these as orphans because the AST walker can't see through the
# dynamic dispatch. They're load-bearing — keep them.
msgid "High"
msgstr "Haute"

msgid "Medium"
msgstr "Moyenne"

msgid "Low"
msgstr "Basse"

msgid "Low AAC"
msgstr "Basse (AAC)"

msgid "High AAC"
msgstr "Haute (AAC)"

msgid "Medium AAC"
msgstr "Moyenne (AAC)"

msgid "Very Low"
msgstr "Très basse"

msgid "Very Low AAC"
msgstr "Très basse (AAC)"

# ── v1.42.x additions ──────────────────────────────────────────────────────

# Section headers grouping the settings page after the v1.42.x
# layout cleanup: UI Language / Project / Conserve power / Debug.
msgid "Project"
msgstr "Projet"

msgid "Conserve power"
msgstr "Économiser la batterie"

msgid "Debug"
msgstr "Débogage"

# v1.42.9 renamed the "Share log" button to include the app name so
# the user knows which suite peer's log is being shared after the
# Android share-sheet hand-off. {app} is filled at rule-eval time
# with APP_NAME (A-Z+T Recorder).
msgid "Share {app} log"
msgstr "Partager le journal de {app}"

# v1.42.0 auto-degrading audio quality: surfaced when a recording
# fails and the ladder drops one rung (container swap then bitrate
# drop). _floor variant is for when we're already at very_low_aac.
msgid "Recording failed; quality lowered. Please try again."
msgstr "Échec de l'enregistrement ; qualité abaissée. Veuillez réessayer."

msgid "Recording failed at the lowest quality. Please try again."
msgstr "Échec de l'enregistrement à la qualité la plus basse. Veuillez réessayer."

# ── v1.45.0 additions ──────────────────────────────────────────────────────

# v1.45.0 work-offline badge on the sync indicator (e.g. "(+3) · offline").
# Rendered when ProjectStatus.work_offline is True per
# CLIENT_INTEGRATION.md § 17b — daemon-wide toggle is on, pending commits
# won't be pushed even when online. Lowercase to compose with the
# preceding parenthesised suffix.
msgid "offline"
msgstr "hors ligne"

# v1.46.36 fourth cell of the work_offline × lan_allow_sync matrix
# (CLIENT_INTEGRATION.md § 17b). Rendered when both flags are on:
# github push is suspended but paired phones still receive over
# LAN. Same composition rules as "offline" — lowercase, follows
# the parenthesised suffix.
msgid "LAN-only"
msgstr "LAN seulement"

# v1.45.0 audit fix: "Share this app" button (main.py KV at line ~514,
# bound to app.share_apk()) was using gettext but had no peer-side
# translation and no client-catalog fallback. Genuine gap, not a
# delegated-to-client string.
msgid "Share this app"
msgstr "Partager cette appli"

# ── v1.48.x — wordlist split (§ 21) ────────────────────────────────────────

# Settings → Filter words prompt above the [2][3][4][5+] team-
# size buttons; visible only in picker mode (when no team_size
# is set yet, or user tapped [change] to revise).
msgid "Split across devices"
msgstr "Répartir entre les appareils"

# Settings → Filter words summary line after a team_size has
# been picked: "Split across {n} devices  [change]".
msgid "Split across {n} devices"
msgstr "Réparti entre {n} appareils"

# Lowercase to match the visual weight of the inline summary
# (it's a tag-style affordance, not a top-level CTA).
msgid "change"
msgstr "modifier"

# Prompt above the [1/n]…[n/n] slot button row (Settings) AND
# inside the auto-fired slot-picker popup.
msgid "Which device is this?"
msgstr "Quel appareil est-ce ?"

# Slot-picker popup title — auto-fires when team_size is set
# AND this device hasn't claimed a slot yet (§ 21 hard rule
# #3 displacement detection).
msgid "Pick a recording slot"
msgstr "Choisir une tranche d'enregistrement"

# Slot-picker popup override button. Shown only when at least
# one slot is already claimed; one-shot — clicking once
# reveals the claimed slots and the button disappears.
msgid "Show claimed slots too"
msgstr "Afficher aussi les tranches occupées"

# 5+ team-size dialog — title + prompt + the numeric input
# accepts ≥ 5.
msgid "Team size"
msgstr "Taille de l'équipe"

msgid "How many devices on the team?"
msgstr "Combien d'appareils dans l'équipe ?"

# Fallback for an empty device_name in the slot-picker popup
# (the inline Settings slot row leaves it blank instead so a
# misconfigured device renders as just "[k/n]"; the popup
# always shows a label).
msgid "Unknown"
msgstr "Inconnu"

# CONTRIBUTOR_UNSET routing per § 21 hard rule #2: both the
# inline Settings slot button and the auto-popup picker route
# the user to the Sync Settings UI when no contributor name is
# set, since claim_slot refuses without one.
msgid "Name required"
msgstr "Nom requis"

msgid ""
"Set your name in Sync Settings before claiming a recording slot. "
"Tap \"Open Sync Settings\" to continue."
msgstr ""
"Définissez votre nom dans les paramètres de synchronisation avant "
"de revendiquer une tranche d'enregistrement. Touchez « Ouvrir les "
"paramètres de synchronisation » pour continuer."
