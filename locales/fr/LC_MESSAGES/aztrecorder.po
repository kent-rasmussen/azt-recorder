msgstr "Démarrage de l’autorisation GitHub…"

msgid "Code copied to clipboard — type it on the GitHub page"
msgstr "Code copié dans le presse-papiers — saisissez-le sur la page GitHub"

msgid "Connected as {username}"
msgstr "Connecté en tant que {username}"

msgid "Connected as {username} — install app for repo access"
msgstr "Connecté en tant que {username} — installez l’appli pour accéder aux dépôts"

