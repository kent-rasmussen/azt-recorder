# =============================================================================
#                            EDIT THIS FILE
#
#   This is the SOURCE template for the A-Z+T Recorder buildozer config.
#   Every build-time configuration change goes here.
#
#   When you change something here, or in one of the vaiables below
#   (and only then), run build_buildozer_spec.sh to rebuild 
#   the buildozer.spec file, by substituting ``${VAR}`` placeholders 
#   with env-var values. That rendered spec is generated per-machine, 
#   gitignored, and recreated on every ``build_buildozer_spec.sh`` 
#   invocation — DO NOT edit it; your changes will be clobbered.
#
#   Workflow:
#       1. Edit this file (buildozer.spec.tmpl).
#       2. Run ``build_buildozer_spec.sh``
#
#   Required env vars (build.sh validates):
#       P4A_HOOK                — absolute path to p4a_hook.py
#       P4A_LOCAL_RECIPES       — absolute path to the local-recipes dir
#       AZT_BUILDOZER_BUILDDIR  — absolute path to the buildozer cache
#                                 (e.g. /home/you/AZT/.buildozer)
#
#   Release-signing env vars (only for ``buildozer android release``;
#   p4a consumes these directly):
#       P4A_RELEASE_KEYSTORE
#       P4A_RELEASE_KEYALIAS
#       P4A_RELEASE_KEYSTORE_PASSWD
#       P4A_RELEASE_KEYALIAS_PASSWD
# =============================================================================

[app]
title = A-Z+T Recorder
package.name = aztrecorder
package.domain = org.atoznback
source.dir = .
source.include_exts = py,png,jpg,kv,atlas,lift,ttf,gz,mo,po
# azt_images/ is 320 MB — too large to bundle in the APK (causes OOM on device).
# Images are accessed from external storage via lift.py's bundled_images_dir logic.
# examples/ is the sister-app symlink to ../azt-collab/examples/ (kill_recovery.py,
# non_kivy_pick.py, sister_app.py) — developer smoke-test scripts, not runtime code,
# don't ship in user APKs.
source.exclude_dirs = azt_images,env,.venv,venv,__pycache__,presplash_variants,examples
# Build-time / dev scripts at the source root. Not imported by main.py at runtime
# (generate_presplash.py builds the multi-density splash; populate_images.py copies
# CAWL images into a LIFT project before publish; strip_langtags.py rebuilds the
# gzipped langtags lookup). Excluded to keep the APK lean and reduce
# "what's this doing in the bundle?" surface for anyone unpacking it.
source.exclude_patterns = generate_presplash.py,populate_images.py,strip_langtags.py
#version = 1.3.1
version.regex = __version__ = ['"](.*)['"]
version.filename = %(source.dir)s/main.py

requirements = python3,kivy==2.3.1,pillow,sounddevice,soundfile,numpy,certifi,filetype,typing_extensions

orientation = portrait
fullscreen = 0

android.permissions = INTERNET,ACCESS_NETWORK_STATE,RECORD_AUDIO,READ_EXTERNAL_STORAGE,WRITE_EXTERNAL_STORAGE,MANAGE_EXTERNAL_STORAGE,CAMERA,REQUEST_INSTALL_PACKAGES,org.atoznback.AZT_COLLAB_ACCESS

# AZT collab ContentProvider lives in the standalone server APK
# (org.atoznback.aztcollab). The recorder is a pure peer: it
# <uses-permission>s the suite signature permission (declared above
# in android.permissions) and <queries> the server APK so
# PackageManager.queryContentProviders can see it on Android 11+.
# Do NOT declare <permission> or <provider> here — the server APK
# owns both. The Java provider class also ships in the server APK,
# so no android.add_src is needed.
#
# `manifest_extras.xml` is a symlink to
# ../azt-collab/android/manifest_extras_peer.xml — the canonical
# peer manifest extras shared by all suite peer apps. See
# azt-collab/CLAUDE.md sister-app integration section.
#
# Note: key is `extra_manifest_xml` (buildozer silently ignores
# `manifest_extra_xml`). Value must be a file path; inline XML is not
# accepted (buildozer does open(value).read()).
android.extra_manifest_xml = %(source.dir)s/manifest_extras.xml
#android.api = 33
android.minapi = 26
android.archs = arm64-v8a, armeabi-v7a
# Force apk (not aab) so the suite can sideload via the bootstrap
# updater and the keystore-signed output is verifiable against
# azt-collab/android/SUITE_FINGERPRINT directly.
#
# Signing config is **not** in this spec. ``android.signing.*`` keys
# are ignored on the APK release path we use — confirmed empirically:
# the spec entry alone does not produce a signed APK. p4a consumes
# env vars instead (see header at top of file).
android.release_artifact = apk

p4a.branch = master
# The hook + local recipes live in a sibling repo (buildozer_tweaks/)
# that maintainers check out next to the AZT suite. Set the env vars
# P4A_HOOK and P4A_LOCAL_RECIPES; build.sh substitutes here.
p4a.hook = ${P4A_HOOK}
p4a.local_recipes = ${P4A_LOCAL_RECIPES}
android.api = 36
#p4a.develop:
android.ndk = 29
#p4a.master:
#android.ndk = 27
#NDK r27's cmake flags don't work with cmake 3.31 — IN_LIST requires cmake policy CMP0057. NDK r28 fixed this (but broke something else):
#android.ndk = 28
#android.release_armeabi_v7a = True

android.add_src = android/src/main/java
# Allow reading files from external storage (shared LIFT files)
android.allow_backup = False

# Legacy icon (pre-API 26 fallback)
icon.filename = %(source.dir)s/icons/icon_dark.png
# Adaptive icon layers (API 26+)
icon.adaptive_foreground.filename = %(source.dir)s/icons/icon_dark.png
icon.adaptive_background.filename = %(source.dir)s/icons/icon_bg.png

presplash.filename = %(source.dir)s/presplash.png
android.presplash_color = #1a1612

# Multi-density presplash variants. generate_presplash.py writes
# six bucket variants (ldpi/mdpi/hdpi/xhdpi/xxhdpi/xxxhdpi) into
# `presplash_variants/drawable-<bucket>/presplash.png`. buildozer
# forwards them to p4a via `--add-resource`; p4a's build.py
# `shutil.copytree`s the contents into the dist's `src/main/res/`
# (with dirs_exist_ok), so each `drawable-<bucket>/presplash.png`
# lands at the canonical Android resource path and the install-
# time DPI bucket selector picks the matching variant.
#
# Coexists with `presplash.filename` above — that creates
# `res/drawable/presplash.jpg` as the universal fallback for
# DPI buckets none of the variants cover (Android falls back
# to plain `drawable/` when no `drawable-<bucket>/` matches).
# The resource id `R.drawable.presplash` resolves across the
# .jpg / .png boundary by base name; aapt2 builds one resource
# entry with the six bucket configs + the .jpg fallback.
#
# Path is per-peer (the recorder's own source.dir) so the
# shared `../azt-collab/android/` tree stays untouched. Other
# peers wanting the same get their own `presplash_variants/`
# directory + the same add_resources line.
android.add_resources = %(source.dir)s/presplash_variants:.

[buildozer]
log_level = 2
warn_on_root = 1
build_dir = ${AZT_BUILDOZER_BUILDDIR}
